# =============================================
# Trade Intelligence Platform - Environment Vars
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git.

# --- ElevenLabs TTS ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_EN_IN=your_indian_english_voice_id
ELEVENLABS_VOICE_ID_TAMIL=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_VOICE_ID_HINDI=your_hindi_voice_id

# --- Email IMAP Credentials ---
EMAIL_USERNAME=your_email@gmail.com
EMAIL_APP_PASSWORD=your_gmail_app_password

# --- LLM (RAG Response Generation) ---
# OpenAI-compatible Chat Completions endpoint.
LLM_API_KEY=your_llm_api_key_here
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1

# Optional: Local DeepSeek via Ollama
# 1) Install Ollama
# 2) Run: ollama pull deepseek-r1:8b
# 3) Set provider/model/base below
# LLM_PROVIDER=ollama
# LLM_MODEL=deepseek-r1:8b
# LLM_BASE_URL=http://127.0.0.1:11434

# If using OpenAI-compatible provider (default), keep:
LLM_PROVIDER=openai-compatible
